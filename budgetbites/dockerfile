# syntax=docker/dockerfile:1

# ------------------------------
# BUILD STAGE (dev deps for build)
# ------------------------------
FROM node:20-alpine AS builder
WORKDIR /app
RUN apk add --no-cache libc6-compat bash curl

# make npm robust over flaky networks
ENV npm_config_loglevel=warn \
    npm_config_fetch_retries=5 \
    npm_config_fetch_retry_mintimeout=20000 \
    npm_config_fetch_retry_maxtimeout=120000 \
    npm_config_registry=https://registry.npmjs.org/ \
    npm_config_audit=false \
    npm_config_fund=false

COPY package*.json ./
# 🔁 retry npm ci up to 5 times
RUN set -eux; \
  for i in 1 2 3 4 5; do \
    npm ci --no-audit --no-fund && break; \
    echo "npm ci failed (attempt $i). sleeping $((i*5))s..."; \
    sleep $((i*5)); \
  done

COPY . .
RUN npm run build

# ------------------------------
# PROD DEPS (only production)
# ------------------------------
FROM node:20-alpine AS prod-deps
WORKDIR /app
ENV npm_config_loglevel=warn \
    npm_config_fetch_retries=5 \
    npm_config_fetch_retry_mintimeout=20000 \
    npm_config_fetch_retry_maxtimeout=120000 \
    npm_config_registry=https://registry.npmjs.org/ \
    npm_config_audit=false \
    npm_config_fund=false

COPY package*.json ./
# 🔁 retry npm ci (prod) up to 5 times
RUN set -eux; \
  for i in 1 2 3 4 5; do \
    npm ci --omit=dev --no-audit --no-fund && break; \
    echo "npm ci (prod) failed (attempt $i). sleeping $((i*5))s..."; \
    sleep $((i*5)); \
  done

# ------------------------------
# FINAL (Nginx + Node)
# ------------------------------
FROM nginx:alpine AS production
WORKDIR /app
RUN apk add --no-cache nodejs bash curl

# Backend build + deps
COPY --from=builder   /app/dist          ./dist
COPY --from=prod-deps /app/node_modules  ./node_modules
COPY --from=builder   /app/package*.json ./

# Frontend build -> Nginx
COPY --from=builder /app/dist/public /usr/share/nginx/html

# Nginx configs
COPY nginx.main.conf /etc/nginx/nginx.conf
COPY nginx.conf      /etc/nginx/conf.d/default.conf
RUN sed -i 's/\r$//' /etc/nginx/nginx.conf /etc/nginx/conf.d/default.conf || true

# Non-root
RUN addgroup -g 1001 -S nodejs && adduser -S appuser -u 1001
RUN chown -R appuser:nodejs /app /var/cache/nginx /var/log/nginx /etc/nginx /usr/share/nginx/html
RUN touch /var/run/nginx.pid && chown appuser:nodejs /var/run/nginx.pid
USER appuser

ENV PORT=5000 HOST=0.0.0.0
EXPOSE 80

# Start Node then Nginx
RUN printf '%s\n' '#!/usr/bin/env bash' \
  'set -e' \
  'node /app/dist/main.js & ' \
  'nginx -g "daemon off;"' > /app/start.sh && chmod +x /app/start.sh

HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
  CMD curl -fsS http://127.0.0.1:5000/health || exit 1

CMD ["/app/start.sh"]
